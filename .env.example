# Lazım olanda VITE_* dəyişənləri buraya əlavə edin.

# PostHog (EU). Скопируйте в файл `.env` (он в .gitignore), подставьте свой ключ из PostHog → Settings → Project API Key.
# Vite подставляет эти переменные на сборке (как в Next.js).
#
# NEXT_PUBLIC_POSTHOG_KEY=phc_ваш_ключ_здесь
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# İstəyə bağlı: Artik mağazasında «PRO / kofe» düymələri üçün tam URL.
# VITE_BUY_ME_A_COFFEE_URL=https://www.buymeacoffee.com/your_username

# Gold VIP (2 AZN) — «İndi Al» düyməsi; boşdursa xəbərdarlıq göstərilir.
# VITE_GOLD_VIP_CHECKOUT_URL=https://example.com/pay-gold-vip
# VIP modal: ödəniş nömrəsi (m10 / kart) + Instagram checkout
# VITE_PAYMENT_PHONE_M10=+994501234567
# VITE_INSTAGRAM_CHECKOUT_URL=https://www.instagram.com/your_username/
# VITE_SUPPORT_INSTAGRAM_URL=https://www.instagram.com/your_username/
# VITE_SUPPORT_INSTAGRAM_HANDLE=your_username

# Firebase (онлайн-дуэль Realtime Database, профиль, друзья). Скопируйте из Firebase Console → Project settings.
# Без API key и projectId приложение запустится, но облачные функции будут отключены (баннер вверху).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_DATABASE_URL=

# İstəyə bağlı: söz izahı üçün POST endpoint (JSON gövdə: wordId, article, word, translation).
# Cavab: { "explanation": "..." } və ya təmiz mətn.
# VITE_WORD_EXPLAIN_URL=

# İstəyə bağlı: Supabase user_progress sinxronu (002_user_progress.sql tətbiq edin).
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
